# Copy to .env and replace every placeholder before starting Docker.
# Never commit the resulting .env file.

POSTGRES_USER=attendx
POSTGRES_PASSWORD=replace-with-a-strong-database-password
POSTGRES_DB=attendx

BETTER_AUTH_SECRET=replace-with-a-random-secret-at-least-32-characters
INTERNAL_JWT_SECRET=replace-with-a-different-random-secret-at-least-32-characters
BETTER_AUTH_URL=http://localhost:10000
CORS_ORIGIN=http://localhost:10000

# First platform owner. This account has access only to /admin, not tenant
# workspaces. Use a unique password of at least 16 characters.
PLATFORM_SUPER_ADMIN_EMAIL=owner@yourcompany.com
PLATFORM_SUPER_ADMIN_PASSWORD=replace-with-a-unique-password-at-least-16-chars
PLATFORM_SUPER_ADMIN_NAME=Platform Owner
PLATFORM_SUPER_ADMIN_RESET_PASSWORD=false

# Demo data is opt-in and must only be used for an isolated local database.
RUN_SEED=false
SEED_DEMO_DATA=false

FACE_SERVICE_URL=http://face-service:4100
FACE_SERVICE_API_KEY=replace-with-an-internal-face-service-key
FACE_SERVICE_TIMEOUT_MS=8000
FACE_MATCH_THRESHOLD=0.6
FACE_QUALITY_MIN_SCORE=0.65
FACE_MODEL_NAME=buffalo_l
FACE_MODEL_HOST_DIR=./models/face
FACE_MODEL_ROOT=/models
FACE_DET_SIZE=640x640

BLOB_READ_WRITE_TOKEN=
BLOB_FACE_PREFIX=face-captures
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
TRIAL_INBOX=
