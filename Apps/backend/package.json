{
  "name": "backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/index.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.658.1",
    "@aws-sdk/s3-request-presigner": "^3.658.1",
    "@better-auth/prisma-adapter": "^1.6.14",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "7.0.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.3",
    "@types/pg": "8.15.4",
    "@types/uuid": "10.0.0",
    "better-auth": "^1.6.14",
    "cors": "2.8.5",
    "dotenv": "17.2.3",
    "exceljs": "4.4.0",
    "express": "5.2.1",
    "express-rate-limit": "7.5.1",
    "firebase-admin": "^13.0.0",
    "helmet": "8.1.0",
    "pdfkit": "^0.15.0",
    "pg": "8.16.3",
    "prisma": "7.0.0",
    "uuid": "11.1.0",
    "winston": "3.19.0",
    "zod": "3.25.64"
  },
  "devDependencies": {
    "@types/node": "22.15.32",
    "@types/pdfkit": "^0.13.4",
    "@types/supertest": "7.2.0",
    "supertest": "7.2.2",
    "tsx": "4.20.6",
    "typescript": "5.8.3",
    "vitest": "4.1.8"
  }
}
