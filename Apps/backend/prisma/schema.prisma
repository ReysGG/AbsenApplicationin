// Prisma schema for AttendX Web Dashboard
// Datasource: Supabase PostgreSQL
// Generator: prisma-client-js

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum EmploymentStatus {
  Active
  Inactive
  Suspended
  Archived
}

enum AccountStatus {
  PendingActivation
  Active
  Disabled
  NoLoginAccess
}

enum AttendanceStatus {
  Present
  Late
  Absent
  PendingCheckout
  MissingCheckout
  Leave
  Invalid
  Duplicate
}

enum WorkMode {
  WFO
  WFH
  Hybrid
}

enum LocationType {
  Office
  Branch
  WFHApproved
}

enum LocationStatus {
  Active
  Inactive
}

enum ShiftStatus {
  Active
  Inactive
}

enum DepartmentStatus {
  Active
  Inactive
}

enum LeaveStatus {
  Pending
  Approved
  Rejected
  Cancelled
}

enum WorkspaceRole {
  stakeholder
  support_admin
  end_user
}

enum ScopeType {
  workspace
  department
  location
}

enum ExportStatus {
  Queued
  Processing
  Completed
  Failed
  Expired
}

enum FaceProfileStatus {
  NotRegistered
  Registered
  NeedReEnrollment
}

enum GlobalRole {
  super_admin
  admin_platform
  user
}

enum TenantStatus {
  Active
  Inactive
  Suspended
}

enum WorkspaceStatus {
  Active
  Inactive
  Suspended
}

enum SyncStatus {
  Synced
  SyncedLate
  Pending
}

enum GeofenceStatus {
  Valid
  Invalid
  Outside
}

enum FaceCheckStatus {
  Passed
  Failed
  Skipped
}

enum SpoofingStatus {
  Clean
  Detected
  Suspected
}

enum ReportType {
  AttendanceSummary
  DailyDetail
  Late
  MissingCheckout
  LeaveAndPermit
  DepartmentAttendance
}

enum ExportFormat {
  XLSX
  CSV
}

enum HolidayStatus {
  Active
  Inactive
}

enum NotificationType {
  leave_request_new
  export_completed
}

enum LeaveSource {
  mobile
  dashboard
}

// ---------------------------------------------------------------------------
// Better-auth tables (managed by better-auth, co-located here for schema sync)
// The column names MUST match better-auth's internal Kysely schema (camelCase).
// ---------------------------------------------------------------------------

model AuthUser {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      AuthSession[]
  accounts      AuthAccount[]

  @@map("user")
}

model AuthSession {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model AuthAccount {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@map("account")
}

model AuthVerification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model Tenant {
  id         String       @id @default(cuid())
  name       String
  slug       String       @unique
  status     TenantStatus @default(Active)
  plan       String?
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  workspaces Workspace[]

  @@map("tenants")
}

model Workspace {
  id                     String          @id @default(cuid())
  tenantId               String          @map("tenant_id")
  name                   String
  timezone               String          @default("Asia/Jakarta")
  defaultGeofenceRadius  Int             @default(100) @map("default_geofence_radius")
  defaultGracePeriod     Int             @default(10) @map("default_grace_period")
  absenceCutoffMinutes   Int             @default(120) @map("absence_cutoff_minutes")
  wfhEnabled             Boolean         @default(false) @map("wfh_enabled")
  hybridEnabled          Boolean         @default(false) @map("hybrid_enabled")
  latePolicy             Json?           @map("late_policy")
  missingCheckoutPolicy  Json?           @map("missing_checkout_policy")
  exportPermissions      Json?           @map("export_permissions")
  status                 WorkspaceStatus @default(Active)
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  tenant           Tenant             @relation(fields: [tenantId], references: [id])
  employees        Employee[]
  departments      Department[]
  locations        Location[]
  shifts           Shift[]
  attendanceLogs   AttendanceLog[]
  attendanceRawLogs AttendanceRawLog[]
  leaveRequests    LeaveRequest[]
  leaveTypes       LeaveType[]
  roleAssignments  RoleAssignment[]
  auditLogs        AuditLog[]
  exportJobs       ExportJob[]
  holidayCalendars HolidayCalendar[]
  notifications    Notification[]
  setting          WorkspaceSetting?

  @@index([tenantId])
  @@map("workspaces")
}

model User {
  id            String        @id @default(cuid())
  authUserId    String        @unique @map("auth_user_id")
  email         String        @unique
  phone         String?
  fullName      String        @map("full_name")
  globalRole    GlobalRole    @default(user) @map("global_role")
  status        AccountStatus @default(Active)
  lastLoginAt   DateTime?     @map("last_login_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  roleAssignments  RoleAssignment[]
  employees        Employee[]
  approvedLeaves   LeaveRequest[]   @relation("LeaveApprover")
  requestedExports ExportJob[]      @relation("ExportRequester")

  @@map("users")
}

model RoleAssignment {
  id          String        @id @default(cuid())
  workspaceId String        @map("workspace_id")
  userId      String        @map("user_id")
  role        WorkspaceRole
  scopeType   ScopeType     @map("scope_type")
  scopeId     String?       @map("scope_id")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  workspace   Workspace                  @relation(fields: [workspaceId], references: [id])
  user        User                       @relation(fields: [userId], references: [id])
  permissions RoleAssignmentPermission[]

  @@unique([workspaceId, userId, role, scopeType, scopeId])
  @@index([workspaceId])
  @@index([userId])
  @@map("role_assignments")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  roleAssignments RoleAssignmentPermission[]

  @@map("permissions")
}

model RoleAssignmentPermission {
  id               String @id @default(cuid())
  roleAssignmentId String @map("role_assignment_id")
  permissionId     String @map("permission_id")

  roleAssignment RoleAssignment @relation(fields: [roleAssignmentId], references: [id])
  permission     Permission     @relation(fields: [permissionId], references: [id])

  @@unique([roleAssignmentId, permissionId])
  @@map("role_assignment_permissions")
}

model Department {
  id          String           @id @default(cuid())
  workspaceId String           @map("workspace_id")
  name        String
  status      DepartmentStatus @default(Active)
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")

  workspace Workspace  @relation(fields: [workspaceId], references: [id])
  employees Employee[]

  @@index([workspaceId])
  @@map("departments")
}

model Location {
  id           String         @id @default(cuid())
  workspaceId  String         @map("workspace_id")
  name         String
  type         LocationType   @default(Office)
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int            @default(100) @map("radius_meters")
  status       LocationStatus @default(Active)
  createdBy    String?        @map("created_by")
  updatedBy    String?        @map("updated_by")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  workspace        Workspace            @relation(fields: [workspaceId], references: [id])
  assignedEmployees Employee[]          @relation("EmployeePrimaryLocation")
  wfhEmployees     EmployeeWfhLocation[]
  attendanceLogs   AttendanceLog[]

  @@index([workspaceId])
  @@map("locations")
}

model Employee {
  id                 String            @id @default(cuid())
  workspaceId        String            @map("workspace_id")
  userId             String?           @map("user_id")
  employeeCode       String            @map("employee_code")
  fullName           String            @map("full_name")
  email              String
  phone              String?
  departmentId       String            @map("department_id")
  position           String?
  employmentStatus   EmploymentStatus  @default(Active) @map("employment_status")
  accountStatus      AccountStatus     @default(PendingActivation) @map("account_status")
  workMode           WorkMode          @default(WFO) @map("work_mode")
  faceProfileStatus  FaceProfileStatus @default(NotRegistered) @map("face_profile_status")
  assignedLocationId String?           @map("assigned_location_id")
  assignedShiftId    String?           @map("assigned_shift_id")
  joinedAt           DateTime          @map("joined_at")
  inactiveAt         DateTime?         @map("inactive_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  workspace           Workspace             @relation(fields: [workspaceId], references: [id])
  user                User?                 @relation(fields: [userId], references: [id])
  department          Department            @relation(fields: [departmentId], references: [id])
  assignedLocation    Location?             @relation("EmployeePrimaryLocation", fields: [assignedLocationId], references: [id])
  assignedShift       Shift?                @relation("EmployeeAssignedShift", fields: [assignedShiftId], references: [id])
  attendanceLogs      AttendanceLog[]
  attendanceRawLogs   AttendanceRawLog[]
  leaveRequests       LeaveRequest[]
  wfhLocations        EmployeeWfhLocation[]

  @@unique([workspaceId, employeeCode])
  @@unique([workspaceId, email])
  @@index([workspaceId])
  @@index([departmentId])
  @@index([workspaceId, employmentStatus])
  @@index([workspaceId, departmentId, employmentStatus])
  @@map("employees")
}

model EmployeeWfhLocation {
  id         String   @id @default(cuid())
  employeeId String   @map("employee_id")
  locationId String   @map("location_id")
  createdAt  DateTime @default(now()) @map("created_at")

  employee Employee @relation(fields: [employeeId], references: [id])
  location Location @relation(fields: [locationId], references: [id])

  @@unique([employeeId, locationId])
  @@map("employee_wfh_locations")
}

model Shift {
  id                       String      @id @default(cuid())
  workspaceId              String      @map("workspace_id")
  name                     String
  startTime                String      @map("start_time")
  endTime                  String      @map("end_time")
  breakMinutes             Int         @default(0) @map("break_minutes")
  gracePeriodMinutes       Int         @default(10) @map("grace_period_minutes")
  checkoutToleranceMinutes Int         @default(60) @map("checkout_tolerance_minutes")
  absenceCutoffMinutes     Int         @default(120) @map("absence_cutoff_minutes")
  workDays                 String[]    @map("work_days")
  effectiveFrom            DateTime    @map("effective_from")
  status                   ShiftStatus @default(Active)
  createdAt                DateTime    @default(now()) @map("created_at")
  updatedAt                DateTime    @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id])
  employees      Employee[]      @relation("EmployeeAssignedShift")
  attendanceLogs AttendanceLog[]

  @@index([workspaceId])
  @@map("shifts")
}

model AttendanceLog {
  id               String           @id @default(cuid())
  workspaceId      String           @map("workspace_id")
  employeeId       String           @map("employee_id")
  attendanceDate   DateTime         @map("attendance_date")
  shiftId          String?          @map("shift_id")
  checkInAt        DateTime?        @map("check_in_at")
  checkOutAt       DateTime?        @map("check_out_at")
  checkInLatitude  Float?           @map("check_in_latitude")
  checkInLongitude Float?           @map("check_in_longitude")
  checkOutLatitude  Float?          @map("check_out_latitude")
  checkOutLongitude Float?          @map("check_out_longitude")
  locationId       String?          @map("location_id")
  workMode         WorkMode?        @map("work_mode")
  faceCheckStatus  FaceCheckStatus? @map("face_check_status")
  geofenceStatus   GeofenceStatus?  @map("geofence_status")
  spoofingStatus   SpoofingStatus?  @map("spoofing_status")
  syncStatus       SyncStatus       @default(Pending) @map("sync_status")
  originalCheckInAt DateTime?       @map("original_check_in_at")
  syncedAt         DateTime?        @map("synced_at")
  status           AttendanceStatus @default(PendingCheckout)
  isDuplicate      Boolean          @default(false) @map("is_duplicate")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  workspace  Workspace @relation(fields: [workspaceId], references: [id])
  employee   Employee  @relation(fields: [employeeId], references: [id])
  shift      Shift?    @relation(fields: [shiftId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id])

  @@index([workspaceId])
  @@index([employeeId])
  @@index([attendanceDate])
  @@index([status])
  // Composite indexes for common dashboard + report queries
  @@index([workspaceId, attendanceDate, status])
  @@index([workspaceId, employeeId, attendanceDate])
  @@index([workspaceId, attendanceDate])
  @@map("attendance_logs")
}

model LeaveRequest {
  id              String      @id @default(cuid())
  workspaceId     String      @map("workspace_id")
  employeeId      String      @map("employee_id")
  type            String
  startDate       DateTime    @map("start_date")
  endDate         DateTime    @map("end_date")
  reason          String?
  attachmentUrl   String?     @map("attachment_url")
  status          LeaveStatus @default(Pending)
  approverId      String?     @map("approver_id")
  approvedAt      DateTime?   @map("approved_at")
  rejectedAt      DateTime?   @map("rejected_at")
  conflictNote    String?     @map("conflict_note")
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  employee  Employee  @relation(fields: [employeeId], references: [id])
  approver  User?     @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([workspaceId])
  @@index([employeeId])
  @@index([status])
  @@index([workspaceId, status])
  @@index([workspaceId, employeeId, status])
  @@map("leave_requests")
}

model ExportJob {
  id                  String       @id @default(cuid())
  workspaceId         String       @map("workspace_id")
  requestedBy         String       @map("requested_by")
  reportType          ReportType   @map("report_type")
  filtersJson         Json         @map("filters_json")
  format              ExportFormat
  rowCount            Int?         @map("row_count")
  status              ExportStatus @default(Queued)
  filePath            String?      @map("file_path")
  signedUrlExpiresAt  DateTime?    @map("signed_url_expires_at")
  requestedAt         DateTime     @default(now()) @map("requested_at")
  completedAt         DateTime?    @map("completed_at")
  errorMessage        String?      @map("error_message")
  createdAt           DateTime     @default(now()) @map("created_at")
  updatedAt           DateTime     @updatedAt @map("updated_at")

  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  requester   User      @relation("ExportRequester", fields: [requestedBy], references: [id])

  @@index([workspaceId])
  @@index([status])
  @@map("export_jobs")
}

model HolidayCalendar {
  id               String        @id @default(cuid())
  workspaceId      String        @map("workspace_id")
  date             DateTime
  name             String
  recurringYearly  Boolean       @default(false) @map("recurring_yearly")
  status           HolidayStatus @default(Active)
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@map("holiday_calendars")
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String?  @map("entity_type")
  entityId    String?  @map("entity_id")
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  requestId   String?  @map("request_id")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([actorUserId])
  @@index([action])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, action, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// AttendanceRawLog — semua attempt mentah dari mobile (R6.10, T10)
// ---------------------------------------------------------------------------

model AttendanceRawLog {
  id                      String   @id @default(cuid())
  workspaceId             String   @map("workspace_id")
  employeeId              String   @map("employee_id")
  eventType               String   @map("event_type") // check_in | check_out
  rawPayloadJson          Json     @map("raw_payload_json")
  deviceTime              DateTime @map("device_time")
  serverReceivedAt        DateTime @default(now()) @map("server_received_at")
  faceResult              String?  @map("face_result")
  geofenceResult          String?  @map("geofence_result")
  spoofingResult          String?  @map("spoofing_result")
  isDuplicate             Boolean  @default(false) @map("is_duplicate")
  isInvalidSequence       Boolean  @default(false) @map("is_invalid_sequence")
  resultingAttendanceLogId String? @map("resulting_attendance_log_id")
  createdAt               DateTime @default(now()) @map("created_at")

  workspace      Workspace      @relation(fields: [workspaceId], references: [id])
  employee       Employee       @relation(fields: [employeeId], references: [id])

  @@index([workspaceId])
  @@index([employeeId])
  @@map("attendance_raw_logs")
}

// ---------------------------------------------------------------------------
// LeaveType — tipe izin/cuti yang dapat dikonfigurasi per workspace (R11.3)
// ---------------------------------------------------------------------------

model LeaveType {
  id                 String   @id @default(cuid())
  workspaceId        String   @map("workspace_id")
  name               String
  requiresAttachment Boolean  @default(false) @map("requires_attachment")
  status             String   @default("Active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([workspaceId, name])
  @@index([workspaceId])
  @@map("leave_types")
}

// ---------------------------------------------------------------------------
// WorkspaceSetting — konfigurasi workspace terpisah (R13)
// ---------------------------------------------------------------------------

model WorkspaceSetting {
  id                      String   @id @default(cuid())
  workspaceId             String   @unique @map("workspace_id")
  lateCalculationPolicy   Json?    @map("late_calculation_policy")
  missingCheckoutPolicy   Json?    @map("missing_checkout_policy")
  exportPermissionsJson   Json?    @map("export_permissions_json")
  displaySettingsJson     Json?    @map("display_settings_json")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@map("workspace_settings")
}

// ---------------------------------------------------------------------------
// Notification — in-app notifikasi untuk leave request baru & export selesai (R21)
// ---------------------------------------------------------------------------

model Notification {
  id                  String           @id @default(cuid())
  workspaceId         String           @map("workspace_id")
  recipientAuthUserId String           @map("recipient_auth_user_id")
  type                NotificationType
  refId               String?          @map("ref_id")
  isRead              Boolean          @default(false) @map("is_read")
  createdAt           DateTime         @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
  @@index([recipientAuthUserId])
  @@index([isRead])
  @@map("notifications")
}
