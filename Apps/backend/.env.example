NODE_ENV=development
PORT=4000

# Supabase PostgreSQL (Transaction / Pooler URL — used by Prisma in production)
DATABASE_URL="postgresql://postgres:[password]@[pooler-host]:6543/postgres?pgbouncer=true&schema=public"

# Supabase Direct Connection URL (required for migrations, bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:[password]@[direct-host]:5432/postgres?schema=public"

# better-auth
BETTER_AUTH_SECRET="change-this-to-a-random-32-char-secret-dev"
BETTER_AUTH_URL="http://localhost:3000"

# BFF internal JWT (shared secret between Next.js BFF and Express)
INTERNAL_JWT_SECRET="change-this-to-a-random-32-char-internal-secret"

# Supabase Storage (needed for leave attachments and export files)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Vercel Blob private storage (attendance face captures)
BLOB_READ_WRITE_TOKEN=""
BLOB_FACE_PREFIX="face-captures"

# Face recognition service (Python FastAPI). Leave empty only if face enrollment
# and attendance face matching are intentionally disabled in local development.
FACE_SERVICE_URL="http://localhost:4100"
# Shared internal credential for face-service /v1/face/analyze. Set this in
# Docker/production; leave empty only for isolated local development.
FACE_SERVICE_API_KEY=""
FACE_SERVICE_TIMEOUT_MS=8000
FACE_MATCH_THRESHOLD=0.6
FACE_QUALITY_MIN_SCORE=0.65

# Firebase Cloud Messaging (FCM) — OPTIONAL.
# Push notifications are auto-disabled when neither var is set; the app still
# works (in-app notifications via createNotification) without these.
#
# Provide ONE of the two:
#   FIREBASE_SERVICE_ACCOUNT_JSON  — paste the entire service-account JSON
#                                    on a single line (escape inner quotes if needed).
#   FIREBASE_SERVICE_ACCOUNT_PATH  — absolute path inside the container,
#                                    e.g. /app/secrets/firebase-service-account.json
#                                    (mount it via docker-compose volumes).
FIREBASE_SERVICE_ACCOUNT_JSON=""
FIREBASE_SERVICE_ACCOUNT_PATH=""

# CORS: Next.js dev server
CORS_ORIGIN="http://localhost:3000"

# SMTP (transactional email). For Gmail use an App Password (not the account
# password) and SMTP_HOST=smtp.gmail.com, SMTP_PORT=587. When SMTP_USER/SMTP_PASS
# are empty the mailer logs the email instead of sending (dev mode).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="AttendX <noreply@example.com>"

# Inbox that receives website trial ("uji coba") requests
TRIAL_INBOX=""

# Public app URL used to build login/activation links in emails
APP_URL="http://localhost:3000"
