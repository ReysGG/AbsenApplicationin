NODE_ENV=development
PORT=4000

# Supabase PostgreSQL (Transaction / Pooler URL — used by Prisma in production)
DATABASE_URL="postgresql://postgres:[password]@[pooler-host]:6543/postgres?pgbouncer=true&schema=public"

# Supabase Direct Connection URL (required for migrations, bypasses PgBouncer)
DIRECT_URL="postgresql://postgres:[password]@[direct-host]:5432/postgres?schema=public"

# better-auth
BETTER_AUTH_SECRET="change-this-to-a-random-32-char-secret-dev"
BETTER_AUTH_URL="http://localhost:3000"

# BFF internal JWT (shared secret between Next.js BFF and Express)
INTERNAL_JWT_SECRET="change-this-to-a-random-32-char-internal-secret"

# Supabase Storage (needed for leave attachments and export files)
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# CORS: Next.js dev server
CORS_ORIGIN="http://localhost:3000"
